# --- Server ---
NODE_ENV=development
# 4000, not 3000 — the rede-pecas-admin React panel runs on 3000 locally
PORT=4000
# Public base URL of this backend (used in staff notification links)
APP_URL=http://localhost:4000

# --- Database (required) ---
DATABASE_URL=postgresql://user:password@localhost:5432/rede_pecas

# --- Redis (optional — falls back to in-memory sessions) ---
REDIS_URL=redis://localhost:6379

# --- Anthropic / Claude (required) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Meta WhatsApp Cloud API (required) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
# Graph API base URL, version included — bump this when Meta deprecates the
# current version instead of editing every call site
WHATSAPP_GRAPH_API_URL=https://graph.facebook.com/v19.0

# --- Auth (required) ---
# Admin panel accounts live in the admin_users table (see db/seed.sql for a dev
# login), not an env var — JWT_SECRET signs their session tokens.
JWT_SECRET=
JWT_ACCESS_EXPIRATION_MINUTES=480
JWT_REFRESH_EXPIRATION_DAYS=30

# --- NHTSA VIN decode (free public API; default is the live endpoint) ---
NHTSA_API_URL=https://vpic.nhtsa.dot.gov/api/vehicles/decodevin
