# --- Server ---
NODE_ENV=development
PORT=3000
# Public base URL of this backend (used in staff notification links)
APP_URL=http://localhost:3000

# --- Database (required) ---
DATABASE_URL=postgresql://user:password@localhost:5432/rede_pecas

# --- Redis (optional — falls back to in-memory sessions) ---
REDIS_URL=redis://localhost:6379

# --- Anthropic / Claude (required) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Meta WhatsApp Cloud API (required) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# --- Auth (required) ---
JWT_SECRET=
JWT_ACCESS_EXPIRATION_MINUTES=60
ADMIN_PASSWORD=

# --- Staff ---
# WhatsApp number that receives payment-proof / in-person payment alerts
STAFF_PHONE_NUMBER=

# --- Primavera ERP (official AGT invoices; mock PDF is used if unset) ---
PRIMAVERA_API_URL=https://api.primavera-angola.ao
PRIMAVERA_API_TOKEN=
