// Rede Peças — Database Diagram (DBML)
// Paste into https://dbdiagram.io to render.
// Mirrors db/schema.sql — keep both in sync when the schema changes.

Project rede_pecas {
  database_type: 'PostgreSQL'
  Note: 'WhatsApp AI parts marketplace — Angola. Extensions: unaccent, pg_trgm.'
}

Table suppliers {
  id serial [pk]
  name text [not null]
  phone text
  email text
  nif text [note: 'Angolan tax ID']
  province text
  rating numeric(2,1) [default: 5.0, note: '0.0 to 5.0']
  api_key text [unique]
  active boolean [default: true]
  created_at timestamptz [default: `NOW()`]
}

Table products {
  id serial [pk]
  supplier_id int [not null, ref: > suppliers.id]
  name text [not null]
  brand text
  reference text [not null]
  oem_reference text
  synonyms text
  category_keywords text [note: 'free text for search']
  description text
  price numeric(12,2) [not null, note: 'Kwanzas (AOA)']
  quantity int [not null, default: 0]
  unit text [default: 'unidade']
  delivery_time text [default: 'Em stock']
  service_offered boolean [default: false, note: 'optional attached service, e.g. installation']
  service_name text
  service_price numeric(12,2)
  active boolean [default: true]
  created_at timestamptz [default: `NOW()`]
  updated_at timestamptz [default: `NOW()`]
  search_vector tsvector [note: 'GENERATED: english FTS (was portuguese, switched 2026-07-14 while catalog data is English) over name/brand/reference/oem_reference/synonyms/category_keywords; GIN indexed']

  indexes {
    (supplier_id, reference) [unique, note: 'batch-import upsert target']
    price
  }
}

Table waitlist_requests {
  id serial [pk]
  product_id int [not null, ref: > products.id]
  customer_phone text [not null]
  created_at timestamptz [default: `NOW()`]
  notified_at timestamptz [note: 'set once the restock notification for this request has gone out']

  indexes {
    product_id
    notified_at
    (product_id, customer_phone) [unique]
  }
}

Table orders {
  id serial [pk]
  number text [unique, not null, note: 'RP-YYYY-XXXXX']
  customer_phone text [not null, ref: > customers.phone]
  product_id int [ref: > products.id]
  supplier_id int [ref: > suppliers.id]
  quantity int [default: 1]
  unit_price numeric(12,2)
  status text [default: 'awaiting_payment', note: 'awaiting_payment (placeholder while service decision pending) → awaiting_stock_confirmation (admin panel) → stock_unavailable (terminal) | awaiting_payment_method → awaiting_bank_subtype | awaiting_in_person_subtype → awaiting_payment_proof | awaiting_agent_confirmation → payment_proof_received → approved | rejected. cancelled: separate terminal status, admin-only, only from a non-terminal status']
  payment_method text [note: 'bank_transfer | bank_deposit | multicaixa_express | mobile_pos | cash']
  approved_by text
  approved_at timestamptz
  customer_engine_number text
  payment_proof_media_id text [note: 'WhatsApp media id; folded in from the former payment_proofs table (strict 1:1 with the order)']
  payment_proof_media_type text
  service_name text [note: 'snapshot of the accepted product service, if any — copied at accept-time like unit_price']
  service_price numeric(12,2)
  stock_confirmation_courtesy_sent boolean [default: false, note: '20-min "still confirming" courtesy message sent once']
  stock_confirmation_admin_reminder_sent boolean [default: false, note: '15-min admin-reminder WhatsApp nudge sent once']
  created_at timestamptz [default: `NOW()`]
  updated_at timestamptz [default: `NOW()`]

  indexes {
    customer_phone
    status
  }
}

Table nhtsa_vehicles {
  vin char(17) [pk]
  make text [not null]
  model text [not null]
  year text [not null]
  vehicle_type text
  engine text
  fuel_type text
  manufacture_country text
  created_at timestamptz [default: `NOW()`]

  Note: 'Avoids repeated NHTSA API calls for the same VIN'
}

Table order_counters {
  year int [pk]
  last_number int [not null, default: 0]

  Note: 'Atomic per-year sequence for order numbers'
}

Table admin_alerts {
  id serial [pk]
  type text [not null, note: 'payment_proof | in_person_payment']
  order_number text [ref: > orders.number]
  message text [not null]
  read_at timestamptz
  created_at timestamptz [default: `NOW()`]

  indexes {
    read_at
    created_at
  }

  Note: 'Admin-panel notification queue — replaces WhatsApp pushes to the admin phone'
}

Table sync_logs {
  id serial [pk]
  supplier_id int [ref: > suppliers.id]
  inserted_count int [default: 0]
  updated_count int [default: 0]
  deactivated_count int [default: 0]
  created_at timestamptz [default: `NOW()`]
}

Table customers {
  phone text [pk, note: 'WhatsApp number']
  name text
  nif text [note: 'Angolan tax ID']
  address text
  email text
  registration_status text [default: 'new', note: 'new → awaiting_name → awaiting_nif → awaiting_nif_number → awaiting_address → awaiting_vehicle_id → complete']
  locale text [note: 'pt | en — detected once from the first message, sticky, NULL resolves to pt']
  first_contact_at timestamptz [default: `NOW()`]
  last_contact_at timestamptz [default: `NOW()`]
  registered_at timestamptz
  contact_count int [default: 1]
  active boolean [default: true]

  indexes {
    registration_status
    last_contact_at
    registered_at
  }
}

Table vehicles {
  phone text [pk, ref: > customers.phone]
  vin char(17)
  make text
  model text
  year text
  engine_number text
  license_plate text
  engine_size text
  fuel_type text
  source text [note: 'vin | manual | document']
  status text [note: 'NULL/complete = confirmed vehicle (4h TTL via updated_at); other = in-progress manual wizard step (30-min TTL via created_at)']
  attempted_vin char(17) [note: 'VIN that failed NHTSA decode before falling back to manual entry']
  created_at timestamptz [default: `NOW()`]
  updated_at timestamptz [default: `NOW()`]

  indexes {
    updated_at
    (status, created_at)
  }

  Note: 'Per-customer identified vehicle — merged from the former vehicle_sessions + manual_vehicle_collections'
}
