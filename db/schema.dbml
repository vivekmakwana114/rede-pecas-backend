// Rede Peças — Database Diagram (DBML)
// Paste into https://dbdiagram.io to render.
// Mirrors db/schema.sql — keep both in sync when the schema changes.

Project rede_pecas {
  database_type: 'PostgreSQL'
  Note: 'WhatsApp AI parts marketplace — Angola. Extensions: unaccent, pg_trgm.'
}

Table suppliers {
  id serial [pk]
  name text [not null]
  phone text
  email text
  nif text [note: 'Angolan tax ID']
  province text
  rating numeric(2,1) [default: 5.0, note: '0.0 to 5.0']
  api_key text [unique]
  active boolean [default: true]
  created_at timestamptz [default: `NOW()`]
}

Table categories {
  id serial [pk]
  name text [not null]
  parent_id int [ref: > categories.id, note: 'subcategories']
}

Table vehicles {
  id serial [pk]
  make text [not null]
  model text [not null]
  generation text
  year_from int [not null]
  year_to int [not null]
  engine text
  fuel_type text

  indexes {
    (make, model)
    (year_from, year_to)
  }
}

Table parts {
  id serial [pk]
  supplier_id int [not null, ref: > suppliers.id]
  category_id int [ref: > categories.id]
  name text [not null]
  brand text
  reference text [not null]
  oem_reference text
  synonyms text
  category_keywords text [note: 'free text for search']
  description text
  price numeric(12,2) [not null, note: 'Kwanzas (AOA)']
  quantity int [not null, default: 0]
  unit text [default: 'unidade']
  delivery_time text [default: 'Em stock']
  active boolean [default: true]
  created_at timestamptz [default: `NOW()`]
  updated_at timestamptz [default: `NOW()`]
  search_vector tsvector [note: 'GENERATED: portuguese FTS over name/brand/reference/oem_reference/synonyms/category_keywords; GIN indexed']

  indexes {
    (supplier_id, reference) [unique, note: 'batch-import upsert target']
    price
  }
}

Table compatibilities {
  id serial [pk]
  part_id int [not null, ref: > parts.id, note: 'ON DELETE CASCADE']
  vehicle_id int [not null, ref: > vehicles.id, note: 'ON DELETE CASCADE']

  indexes {
    (part_id, vehicle_id) [unique]
  }
}

Table orders {
  id serial [pk]
  number text [unique, not null, note: 'RP-YYYY-XXXXX']
  customer_phone text [not null, ref: > customers.phone]
  part_id int [ref: > parts.id]
  supplier_id int [ref: > suppliers.id]
  quantity int [default: 1]
  unit_price numeric(12,2)
  status text [default: 'awaiting_payment', note: 'awaiting_payment → awaiting_payment_method → awaiting_bank_subtype | awaiting_in_person_subtype → awaiting_payment_proof | awaiting_agent_confirmation → payment_proof_received → approved | rejected']
  payment_method text [note: 'bank_transfer | bank_deposit | multicaixa_express | mobile_pos | cash']
  approved_by text
  approved_at timestamptz
  customer_engine_number text
  created_at timestamptz [default: `NOW()`]
  updated_at timestamptz [default: `NOW()`]

  indexes {
    customer_phone
    status
  }
}

Table waitlist_requests {
  id serial [pk]
  phone text [not null]
  part_name text [not null]
  vehicle_make text
  vehicle_model text
  vehicle_year text
  engine_number text
  notified boolean [default: false]
  created_at timestamptz [default: `NOW()`]

  Note: 'Parts not found in stock — notify customer when available'
}

Table vin_cache {
  vin char(17) [pk]
  make text [not null]
  model text [not null]
  year text [not null]
  vehicle_type text
  engine text
  fuel_type text
  manufacture_country text
  created_at timestamptz [default: `NOW()`]

  Note: 'Avoids repeated NHTSA API calls'
}

Table vehicle_sessions {
  phone text [pk]
  vin char(17)
  make text
  model text
  year text
  engine_number text
  license_plate text
  engine_size text
  fuel_type text
  updated_at timestamptz [default: `NOW()`, note: '4-hour working context']
}

Table manual_vehicle_collections {
  phone text [pk]
  status text [not null, note: 'awaiting_make → awaiting_model → awaiting_year → awaiting_engine_number → complete']
  attempted_vin char(17)
  make text
  model text
  year text
  engine_number text
  created_at timestamptz [default: `NOW()`, note: '30-minute TTL enforced in queries']
}

Table payment_proofs {
  order_number text [pk, ref: > orders.number]
  media_id text [not null, note: 'WhatsApp media id']
  media_type text
  created_at timestamptz [default: `NOW()`]
}

Table order_counters {
  year int [pk]
  last_number int [not null, default: 0]

  Note: 'Atomic per-year sequence for order numbers'
}

Table sync_logs {
  id serial [pk]
  supplier_id int [ref: > suppliers.id]
  inserted_count int [default: 0]
  updated_count int [default: 0]
  deactivated_count int [default: 0]
  created_at timestamptz [default: `NOW()`]
}

Table customers {
  phone text [pk, note: 'WhatsApp number']
  name text
  nif text [note: 'Angolan tax ID']
  address text
  email text
  registration_status text [default: 'new', note: 'new → awaiting_name → awaiting_nif → awaiting_address → complete']
  first_contact_at timestamptz [default: `NOW()`]
  last_contact_at timestamptz [default: `NOW()`]
  registered_at timestamptz
  contact_count int [default: 1]
  active boolean [default: true]

  indexes {
    registration_status
    last_contact_at
    registered_at
  }
}

Table campaign_sends {
  id serial [pk]
  phone text [ref: > customers.phone]
  segment text [note: 'all | inactive_30_days | diesel | luanda | frequent_buyers | no_orders | toyota | new_7_days']
  sent_at timestamptz [default: `NOW()`]
}
