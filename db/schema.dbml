// Rede Peças — Database Diagram (DBML)
// Paste into https://dbdiagram.io to render.
// Mirrors db/schema.sql — keep both in sync when the schema changes.

Project rede_pecas {
  database_type: 'PostgreSQL'
  Note: 'WhatsApp AI parts marketplace — Angola. Extensions: unaccent, pg_trgm.'
}

Table suppliers {
  id serial [pk]
  name text [not null]
  phone text
  email text
  nif text [note: 'Angolan tax ID']
  province text
  rating numeric(2,1) [default: 5.0, note: '0.0 to 5.0']
  api_key text [unique]
  active boolean [default: true]
  created_at timestamptz [default: `NOW()`]
}

Table products {
  id serial [pk]
  supplier_id int [not null, ref: > suppliers.id]
  name text [not null]
  brand text [note: 'also holds the catalog CSV part_brand']
  reference text [not null]
  oem_reference text
  synonyms text [not null]
  category_keywords text [note: 'free text for search']
  description text [not null]
  category text [not null, note: 'part | lubricant']
  subcategory text [not null, note: 'Brakes, Engine, Filtration, Mechanical, Steering, Suspension, Transmission, Engine Oil']
  service_category text [not null, note: 'derived from subcategory via SUBCATEGORY_TO_SERVICE_CATEGORY; join key against services.service_category']
  vehicle_make text [not null]
  vehicle_model text
  year_start int
  year_end int
  engine text [note: 'engine this part fits, not the customer vehicle (see vehicles.engine_number)']
  engine_number text
  viscosity text [note: 'lubricant-only']
  engine_type text [note: 'lubricant-only']
  volume_liters numeric(5,2) [note: 'lubricant-only']
  specification text
  interval_km int
  image_url text
  delivery_time text [not null]
  price numeric(12,2) [not null, note: 'Kwanzas (AOA)']
  quantity int [not null, default: 0]
  unit text [default: 'unidade']
  active boolean [default: true]
  created_at timestamptz [default: `NOW()`]
  updated_at timestamptz [default: `NOW()`]
  search_vector tsvector [note: 'GENERATED: english FTS (was portuguese, switched 2026-07-14 while catalog data is English) over name/brand/reference/oem_reference/synonyms/category_keywords; GIN indexed']

  indexes {
    (supplier_id, reference) [unique, note: 'batch-import upsert target']
    price
    service_category
  }
}

Table service_providers {
  id serial [pk]
  name text [not null]
  address text
  province text
  phone text
  specialties text
  rating numeric(2,1) [default: 5.0]
  response_time text
  active boolean [default: true]
  created_at timestamptz [default: `NOW()`]

  Note: 'Separate from suppliers (parts suppliers) — home-visit service providers'
}

Table services {
  id serial [pk]
  provider_id int [not null, ref: > service_providers.id]
  service_name text [not null]
  service_category text [not null, note: 'maintenance | general_mechanics | diagnostics']
  service_base_price numeric(12,2) [not null]
  service_duration_h numeric(4,2) [not null]
  available_at_home boolean [not null, default: false]
  base_travel_fee numeric(12,2)
  logistics_fee_notes text
  active boolean [default: true]
  created_at timestamptz [default: `NOW()`]
  updated_at timestamptz [default: `NOW()`]

  indexes {
    provider_id
    service_category
    (provider_id, service_name) [unique, note: 'upsert target']
  }

  Note: 'service_category is the join key against products.service_category'
}

Table waitlist_requests {
  id serial [pk]
  product_id int [not null, ref: > products.id]
  customer_phone text [not null]
  created_at timestamptz [default: `NOW()`]
  notified_at timestamptz [note: 'set once the restock notification for this request has gone out']

  indexes {
    product_id
    notified_at
    (product_id, customer_phone) [unique]
  }
}

Table orders {
  id serial [pk]
  number text [unique, not null, note: 'RP-YYYY-XXXXX']
  customer_phone text [not null, ref: > customers.phone]
  product_id int [ref: > products.id]
  supplier_id int [ref: > suppliers.id]
  quantity int [default: 1]
  unit_price numeric(12,2)
  status text [default: 'awaiting_payment', note: 'awaiting_payment (placeholder while service decision pending) → awaiting_stock_confirmation (admin panel) → stock_unavailable (terminal) | awaiting_payment_method → awaiting_bank_subtype (transfer/deposit only) → awaiting_payment_proof | awaiting_agent_confirmation → payment_proof_received → approved | rejected. cancelled: legacy value, no longer set by any code path — see admin_hidden']
  payment_method text [note: 'bank_transfer | bank_deposit | multicaixa_express | mobile_pos']
  approved_by text
  approved_at timestamptz
  customer_engine_number text
  payment_proof_media_id text [note: 'WhatsApp media id; folded in from the former payment_proofs table (strict 1:1 with the order)']
  payment_proof_media_type text
  service_name text [note: 'snapshot of the accepted matched service (from services table, chosen via product.service_category), if any — copied at accept-time like unit_price']
  service_price numeric(12,2)
  stock_confirmation_courtesy_sent boolean [default: false, note: '20-min "still confirming" courtesy message sent once']
  stock_confirmation_admin_reminder_sent boolean [default: false, note: '15-min admin-reminder WhatsApp nudge sent once']
  admin_hidden boolean [default: false, note: 'admin-grid-only soft delete, approved orders only (DELETE /admin/orders/:number) — never touches the real order/customer, no notification sent']
  created_at timestamptz [default: `NOW()`]
  updated_at timestamptz [default: `NOW()`]

  indexes {
    customer_phone
    status
  }
}

Table nhtsa_vehicles {
  vin char(17) [pk]
  make text [not null]
  model text [not null]
  year text [not null]
  vehicle_type text
  engine text
  fuel_type text
  manufacture_country text
  created_at timestamptz [default: `NOW()`]

  Note: 'Avoids repeated NHTSA API calls for the same VIN'
}

Table order_counters {
  year int [pk]
  last_number int [not null, default: 0]

  Note: 'Atomic per-year sequence for order numbers'
}

Table admin_alerts {
  id serial [pk]
  type text [not null, note: 'payment_proof | in_person_payment']
  order_number text [ref: > orders.number]
  message text [not null]
  read_at timestamptz
  created_at timestamptz [default: `NOW()`]

  indexes {
    read_at
    created_at
  }

  Note: 'Admin-panel notification queue — replaces WhatsApp pushes to the admin phone'
}

Table sync_logs {
  id serial [pk]
  supplier_id int [ref: > suppliers.id]
  inserted_count int [default: 0]
  updated_count int [default: 0]
  deactivated_count int [default: 0]
  created_at timestamptz [default: `NOW()`]
}

Table customers {
  phone text [pk, note: 'WhatsApp number']
  name text
  nif text [note: 'Angolan tax ID']
  address text
  email text
  registration_status text [default: 'new', note: 'new → awaiting_name → awaiting_nif → awaiting_nif_number → awaiting_address → awaiting_vehicle_id → complete']
  first_contact_at timestamptz [default: `NOW()`]
  last_contact_at timestamptz [default: `NOW()`]
  registered_at timestamptz
  contact_count int [default: 1]
  active boolean [default: true]

  indexes {
    registration_status
    last_contact_at
    registered_at
  }
}

Table vehicles {
  phone text [pk, ref: > customers.phone]
  vin char(17)
  make text
  model text
  year text
  engine_number text
  license_plate text
  engine_size text
  fuel_type text
  source text [note: 'vin | manual | document']
  status text [note: 'NULL/complete = confirmed vehicle (4h TTL via updated_at); other = in-progress manual wizard step (30-min TTL via created_at)']
  attempted_vin char(17) [note: 'VIN that failed NHTSA decode before falling back to manual entry']
  created_at timestamptz [default: `NOW()`]
  updated_at timestamptz [default: `NOW()`]

  indexes {
    updated_at
    (status, created_at)
  }

  Note: 'Per-customer identified vehicle — merged from the former vehicle_sessions + manual_vehicle_collections'
}
